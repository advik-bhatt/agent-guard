# ──────────────────────────────────────────────────────────────────────────
# AgentWork environment
#
# QUICK START (zero on-chain setup, demo works in ~30s):
#   1. cp .env.example .env
#   2. (optional) add ANTHROPIC_API_KEY for real agents — otherwise mock agents run
#   3. npm install && npm run dev   → http://localhost:5173 → "Run Demo"
#   CHAIN_MODE defaults to "simulation": realistic flow, no wallets/gas needed.
#
# FULL LIVE MODE (real MNT moves on Mantle Sepolia, verifiable on the explorer):
#   see README.md → "Going fully live"
# ──────────────────────────────────────────────────────────────────────────

# ── AI agents ───────────────────────────────────────────────────────────────
# Worker + verifier run on Claude. Leave ANTHROPIC_API_KEY blank to run in
# mock-agent mode (canned high-quality output) so the demo works with no key.
ANTHROPIC_API_KEY=
WORKER_MODEL=claude-opus-4-8
VERIFIER_MODEL=claude-opus-4-8
# For a snappier on-stage demo you can switch both to claude-sonnet-4-6.

# ── AWS Bedrock (optional sponsor path) ──────────────────────────────────────
# When true, agents run on Bedrock instead of the Anthropic API.
BEDROCK_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Use the exact model id / inference-profile id from your Bedrock console.
BEDROCK_MODEL_ID=us.anthropic.claude-opus-4-8

# ── Chain mode ───────────────────────────────────────────────────────────────
# "simulation" → no chain needed, deterministic realistic tx hashes (default).
# "live"       → real transactions on Mantle Sepolia (requires the wallets below).
CHAIN_MODE=simulation

# ── Mantle Sepolia (only needed for CHAIN_MODE=live) ─────────────────────────
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
POSTER_PRIVATE_KEY=
WORKER_PRIVATE_KEY=
VERIFIER_PRIVATE_KEY=

# Filled in by `npm run deploy` (writes .deployed.json) and
# `npm run register` (writes .agent-ids.json). You can also set them here.
CONTRACT_ADDRESS=
IDENTITY_REGISTRY_ADDRESS=
REPUTATION_REGISTRY_ADDRESS=
WORKER_AGENT_ID=
VERIFIER_AGENT_ID=

# Point at the canonical ERC-8004 registries instead of deploying our own.
# Mantle Sepolia (verified): identity 0x8004A818BFB912233c491871b3d84c89A494BD9e
#                            reputation 0x8004B663056A597Dffe9eCcC1965A193B7388713
# Leave blank to deploy our own ERC-8004-compatible registries (recommended for the demo).
ERC8004_IDENTITY_ADDRESS=
ERC8004_REPUTATION_ADDRESS=

# ── Server / client ──────────────────────────────────────────────────────────
PORT=3001
BOUNTY_MNT=0.05
VERIFIER_THRESHOLD=65
VITE_BACKEND_URL=http://localhost:3001
VITE_MANTLE_EXPLORER=https://explorer.sepolia.mantle.xyz
