# ── AgentGuard environment ───────────────────────────────────────────────────
# Zero-config: leave everything blank → mock agent + simulated anchor, full demo
# still runs. Fill in below to make each sponsor real.

# ── Agent runtime (AWS Bedrock preferred; Anthropic fallback; mock if neither) ──
BEDROCK_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

ANTHROPIC_API_KEY=
WORKER_MODEL=claude-opus-4-8

# ── Perseus (policy derived from the agent's codebase) ───────────────────────
# pip install perseus-ctx   (then set this true to use the real engine)
PERSEUS_ENABLED=false

# ── The agent under guard + budget ───────────────────────────────────────────
AGENT_REPO=               # defaults to ./fixtures/support-agent
GUARD_BUDGET_USD=25

# ── On-chain anchor (non-repudiable audit root) ──────────────────────────────
CHAIN_MODE=simulation     # "live" to anchor for real on an EVM testnet
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
VITE_MANTLE_EXPLORER=https://explorer.sepolia.mantle.xyz
ANCHOR_PRIVATE_KEY=       # any funded EVM testnet key (live mode only)

# ── Persistence (optional — in-memory if unset) ──────────────────────────────
DATABASE_URL=

# ── Server / client ──────────────────────────────────────────────────────────
PORT=3001
VITE_BACKEND_URL=http://localhost:3001   # set EMPTY on Replit (same-origin)
